{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "dynamo-sage-local": {
      "type": "local",
      "command": ["./dynamo-sage"],
      "enabled": true,
      "env": {
        "DYNAMO_SAGE_CONFIG": "config.yaml",
        "DYNAMO_SAGE_DB": "data/audit.db",
        "DYNAMO_SAGE_ADDR": ":8080"
      }
    },
    "dynamo-sage-aws": {
      "type": "sse",
      "url": "http://dynamodb-sage-alb-421740889.eu-north-1.elb.amazonaws.com/sse",
      "enabled": true
    }
  }
}
