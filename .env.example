# DynamoDB
AWS_BASE_ENDPOINT=http://localstack:4566
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=<your_access_key>
AWS_SECRET_ACCESS_KEY=<your_secret_key>
LOCALSTACK_AUTH_TOKEN=<your_token_here>

# App
CONFIG_PATH=config.yaml
DYNAMO_SAGE_DB=data/audit.db
DYNAMO_SAGE_ADDR=:8080
MCP_TRANSPORT_MODE=stdio
METRICS_ADDR=:2112

# Kafka (docker: kafka:9092, local: localhost:9093)
KAFKA_BROKERS=kafka:9092
KAFKA_CONFIG_PATH=/app/config/kafka.yaml

# LLM (Anthropic)
LLM_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-5
LLM_BASE_URL=https://api.anthropic.com
LLM_API_KEY_PARAM=/dynamodb-sage/claude/api-key
LLM_TIMEOUT_SEC=30

# OpenAI (embeddings)
OPENAI_API_KEY=sk-proj-...
OPENAI_API_KEY_PARAM=/dynamodb-sage/openai/api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# Qdrant (docker: adrant, local: localhost)
QDRANT_HOST=adrant

# CORS (production domain, or * for local dev)
CORS_ORIGIN=*
